# ============================================================
# RecruiterStack — environment variable template
# Duplicate this file as .env.local and populate the values.
# Never commit .env.local to version control.
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional — enables AI email drafting on candidate profiles
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Optional — Upstash rate limiting (required for public endpoint protection)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Optional — Supabase type generation
SUPABASE_PROJECT_ID=your-project-ref

# Optional — OAuth CSRF state signing (falls back to CLERK_SECRET_KEY)
OAUTH_STATE_SECRET=your-random-secret

# Optional — Encrypt OAuth tokens at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
