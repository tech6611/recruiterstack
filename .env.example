# ============================================================
# RecruiterStack — environment variable template
# Duplicate this file as .env.local and populate the values.
# Never commit .env.local to version control.
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional — enables AI email drafting on candidate profiles
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Optional — Upstash rate limiting (required for public endpoint protection)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Optional — Supabase type generation
SUPABASE_PROJECT_ID=your-project-ref

# Optional — OAuth CSRF state signing (falls back to CLERK_SECRET_KEY)
OAUTH_STATE_SECRET=your-random-secret

# Optional — Encrypt OAuth tokens at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Clerk webhook signing secret (from Clerk Dashboard → Webhooks → Endpoint)
# Used to verify events posted to /api/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Slack signing secret (from Slack App → Basic Information → Signing Secret)
# Used to verify interactive button + modal POSTs to /api/slack/interactions
SLACK_SIGNING_SECRET=

# Optional — WhatsApp (Meta Cloud API). Per-org credentials live in the
# whatsapp_accounts table (Settings → Integrations → WhatsApp); these are the
# app-level values for the shared webhook endpoint /api/webhooks/whatsapp.
# Verify token: any random string — enter the same value in Meta App → WhatsApp
# → Configuration when registering the callback URL.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Fallback app secret for webhook HMAC verification (per-org app_secret is
# checked first)
WHATSAPP_APP_SECRET=
# Default country (ISO alpha-2) applied to national-format phone numbers
WHATSAPP_DEFAULT_COUNTRY=IN
